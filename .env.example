# Backend Environment Variables
# Copie este arquivo para .env na pasta backend/ e preencha com seus valores

# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_aqui

# Prompt Customizado para Adaptação de Textos
# Este é o system prompt que será usado pelo LLMProvider
# para orientar a adaptação de textos de Platão para português acessível
# Você DEVE gerar seu próprio prompt customizado aqui
ADAPTATION_PROMPT=sua_instrucao_customizada_aqui

# (Opcional) Chave de API Anthropic para suporte futuro a Claude
# ANTHROPIC_API_KEY=sua_chave_aqui

# Backend Port (opcional, padrão 3000)
# PORT=3000

# Node Environment
# NODE_ENV=development
